name: Update Snyk-UI Project
on:
  push:
    branches: [main]
jobs:
  security:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@master
      - name: Upload dependancy tree to Snyk-UI
        uses: snyk/actions/node@master
        env:
          SNYK_TOKEN: ${{ secrets.SNYK_TOKEN }}
        with:
          command: monitor # Default command is `test`
          args: |
            --all-projects
            --fail-fast
            --debug
# other args:
            # --reachability=<true|false>
            # --exclude=<NAME>[,<NAME>]...>
            # --prune-repeated-subdependencies
            # --project-name=<PROJECT_NAME>
            # --ignore-policy
            # --trust-policy
